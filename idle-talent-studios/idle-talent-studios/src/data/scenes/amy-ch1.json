          "id": "n1-l1",
          "speaker": "Amy Crawford",
          "text": "So. You're the new one everyone's been whispering about."
        },
        {
          "id": "n1-l2",
          "speaker": "Amy Crawford",
          "text": "I make a point of introducing myself before the industry does it for me."
        }
      ],
      "choices": [
        {
          "id": "c1",
          "text": "\"I've heard a lot about you too.\"",
          "affectionDelta": { "characterId": "amy-crawford", "delta": 3 },
          "nextNodeId": "n2-confident"
        },
        {
          "id": "c2",
          "text": "\"I wasn't expecting to meet you this early.\"",
          "affectionDelta": { "characterId": "amy-crawford", "delta": 1 },
          "nextNodeId": "n2-neutral"
        },
        {
          "id": "c3",
          "text": "\"[Confidence 30] Play it as cool as she does.\"",
