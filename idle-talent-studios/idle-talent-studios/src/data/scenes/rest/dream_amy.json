      "lines": [
        { "id": "d1-l1", "speaker": "", "text": "The city lights blur past a window you don't recognize. Soft jazz from somewhere. And then — her." }
      ],
      "autoNext": "d2"
    },
    {
      "id": "d2",
      "lines": [
        { "id": "d2-l1", "speaker": "Amy", "text": "You always look like you're thinking about something you won't say out loud." }
      ],
      "autoNext": "d3",
      "autoAdvanceMs": 4000
    },
    {
      "id": "d3",
      "lines": [
        { "id": "d3-l1", "speaker": "Amy", "text": "For what it's worth — I think about you too. When the city gets quiet." }
      ],
      "autoNext": "d4",
      "autoAdvanceMs": 4200,
      "affectionDeltas": [{ "characterId": "amy-crawford", "delta": 3 }]
    },
    {
