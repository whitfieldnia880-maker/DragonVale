      "type": "inner_monologue",
      "autoAdvanceMs": 3000,
      "lines": [
        { "id": "d4-l1", "speaker": "", "text": "The alarm pulls you back before you answer. But the warmth lingers." }
      ],
      "autoNext": "d-end"
    },
